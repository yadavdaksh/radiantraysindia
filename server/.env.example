# =============================================================
# RADIANT RAYS API - Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# Server runs on PORT=4000
# =============================================================

# ─── SERVER ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────────
# Neon PostgreSQL (or any PostgreSQL connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ─── JWT SECRETS ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_JWT_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ACCESS_TOKEN_LIFE=15m
REFRESH_TOKEN_LIFE=7d

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── FRONTEND URL ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── CLOUDFLARE R2 (File Storage) ─────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-custom-r2-domain.com

# ─── RAZORPAY (Payments) ──────────────────────────────────────
# Leave blank or set to rzp_test_mock to use mock mode
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── BREVO / SMTP (Email) ─────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@email.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=no-reply@radiantraysindia.com
SMTP_FROM_NAME=Radiant Rays

# ─── SHIPROCKET (Shipping) ────────────────────────────────────
# Credentials are stored in DB (Settings table) via admin panel
# These env vars are optional overrides
SHIPROCKET_EMAIL=your_shiprocket_account@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# ─── ENCRYPTION (for Shiprocket password encryption in DB) ────
ENCRYPTION_KEY=your_32_character_encryption_key_here

# ─── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
